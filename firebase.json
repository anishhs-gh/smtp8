{
  "hosting": {
    "site": "smtp8",
    "public": "frontend/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api",
        "region": "us-central1"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "backend",
    "codebase": "smtp8-api",
    "predeploy": ["npm --prefix backend install --omit=dev", "npm --prefix backend run build"]
  },
  "emulators": {
    "hosting": {
      "host": "127.0.0.1",
      "port": 5001
    },
    "functions": {
      "host": "127.0.0.1",
      "port": 5002
    },
    "hub": {
      "host": "127.0.0.1",
      "port": 4401
    },
    "logging": {
      "host": "127.0.0.1",
      "port": 4501
    }
  }
}
