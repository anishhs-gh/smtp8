# SMTP8 — Backend environment variables
# Copy to .env and fill in real values for local development.
# In production these are set via Firebase Functions config or Cloud Run env vars.

# Port the Express server listens on (standalone / local dev only).
# Cloud Run overrides this automatically; Firebase Functions ignores it.
PORT=8081

# Comma-separated list of allowed CORS origins.
# Add your Firebase Hosting URL and any custom domain.
ALLOWED_ORIGINS=http://localhost:5173,https://smtp8.web.app,https://smtp8-ws.web.app
