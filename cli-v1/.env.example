# SMTP8 CLI — environment variables
# These can be set in your shell profile or passed inline before the command.
#
# Example:
#   export SMTP8_API_URL=https://api.yourdomain.com
#   smtp8
#
# Or inline:
#   SMTP8_API_URL=https://api.yourdomain.com smtp8

# Base URL of the SMTP8 API. Defaults to http://localhost:8081 if not set.
SMTP8_API_URL=http://localhost:8081
