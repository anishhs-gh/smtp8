# SMTP8 — Frontend environment variables
# Copy to .env.local for local development.
# For production, set VITE_API_BASE_URL in your CI environment or .env.production.
#
# When deployed together with Firebase Functions use a relative path (/api)
# so the hosting rewrite proxies requests to the function — no CORS needed.
#
# When the API is on a separate domain (Cloud Run, VPS) use the full URL.

# Local development (backend running on :8081)
VITE_API_BASE_URL=http://localhost:8081

# Production — call Cloud Run directly to bypass Firebase Hosting's Fastly CDN,
# which buffers streaming responses (NDJSON) and breaks live protocol events.
# VITE_API_BASE_URL=https://api-ne2iz2roeq-uc.a.run.app

# VPS deployment
# VITE_API_BASE_URL=https://api.yourdomain.com
